{
  "name": "scratch-ai-server-workspace",
  "private": true,
  "description": "Open source workspace for the Scratch AI teaching server and teacher dashboard",
  "license": "AGPL-3.0",
  "homepage": "https://github.com/scratchai-labs/scratch-ai-server#readme",
  "bugs": {
    "url": "https://github.com/scratchai-labs/scratch-ai-server/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scratchai-labs/scratch-ai-server.git"
  },
  "workspaces": [
    "apps/server-web"
  ],
  "scripts": {
    "build": "npm run server:web:build && npm run server:api:build",
    "test": "npm run server:web:test && npm run server:api:test",
    "verify": "npm run test",
    "clean": "node scripts/cleanup-workspace.mjs",
    "clean:dry-run": "node scripts/cleanup-workspace.mjs --dry-run",
    "server:dev": "node scripts/dev-server-stack.mjs",
    "server:test": "npm run server:web:test && npm run server:api:test",
    "server:build": "npm run server:web:build && npm run server:api:build",
    "server:api:dev": "cd apps/server-api && go run ./cmd/server-api",
    "server:api:build": "cd apps/server-api && go build ./cmd/server-api",
    "server:api:test": "cd apps/server-api && go test ./...",
    "server:web:dev": "npm run dev --workspace=@scratch-ai/server-web",
    "server:web:build": "npm run build --workspace=@scratch-ai/server-web",
    "server:web:test": "npm run test --workspace=@scratch-ai/server-web",
    "workspace:clean": "npm run clean",
    "workspace:clean:dry-run": "npm run clean:dry-run"
  }
}
